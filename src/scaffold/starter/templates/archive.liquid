{% layout 'layouts/base' %}
<div class="container archive">
  <header class="archive-header">
    <h1>{{ archive.title | default: "Blog" }}</h1>
  </header>
  {% for item in posts %}
    {% unless forloop.first %}<hr />{% endunless %}
    <article class="post-item">
      {% if item.cover_image %}
        <figure>
          <a href="{{ site.locale_prefix }}/{{ item.slug }}">
            <img src="{{ item.cover_image }}" alt="" loading="lazy" />
          </a>
        </figure>
      {% endif %}
      <h2><a href="{{ site.locale_prefix }}/{{ item.slug }}">{{ item.title }}</a></h2>
      {% if item.excerpt %}<p>{{ item.excerpt }}</p>{% endif %}
      <div class="post-item-footer">
        <span class="post-item-date">— {{ item.published_at | post_date }}</span>
      </div>
    </article>
  {% else %}
    <p>{% if route.locale == 'en' %}No content published.{% else %}Nenhum conteúdo publicado.{% endif %}</p>
  {% endfor %}
  {% pagination %}
</div>
