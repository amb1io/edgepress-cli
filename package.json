    "commander": "^13.1.0",
    "liquidjs": "^10.27.1",
    "nanotar": "^0.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "esbuild": "^0.25.12",
